########################################
# Stack Updater — example config
#
# Copy this file to:
#   config.env
#
# Then edit values for your host:
#   cp config.env.example config.env
#   chmod 600 config.env
#
# Notes:
# - Bash syntax is required.
# - Use straight quotes, not smart quotes.
# - Do not commit config.env; it contains your Portainer API key.
########################################


########################################
# PATHS
########################################

# Optional log path.
# If unset, the script writes stack-updater.log next to stack-updater.sh.
#
# LOG_FILE="/opt/scripts/Stack-Updater/stack-updater.log"

# Optional chained config file.
# Useful if you want config.env to load secrets or local overrides from another file.
#
# CONFIG_FILE="/opt/scripts/Stack-Updater/config.env.local"


########################################
# PORTAINER API
########################################

# Portainer URL reachable from the host running stack-updater.sh.
# Same-host Portainer commonly uses HTTPS on 9443.
PORTAINER_URL="https://127.0.0.1:9443"

# Portainer API key.
# Create this from your Portainer user/account settings.
PORTAINER_API_KEY="PASTE_YOUR_PORTAINER_API_KEY_HERE"

# Portainer Docker environment ID.
# Check Portainer → Environments, or query /api/endpoints.
# This is often 1, but may be 2, 3, etc.
ENDPOINT_ID="1"


########################################
# PORTAINER CONTAINER SELF-UPDATE
########################################

# Local Portainer container name.
PORTAINER_CONTAINER_NAME="portainer"

# Portainer CE release stream:
#   lts    → portainer/portainer-ce:lts
#   sts    → portainer/portainer-ce:sts
#   custom → use PORTAINER_IMAGE exactly as written
PORTAINER_RELEASE_STREAM="lts"

# Used only when PORTAINER_RELEASE_STREAM="custom".
# For lts/sts, the script derives the image automatically.
PORTAINER_IMAGE="portainer/portainer-ce:lts"

# Use Cup as a pre-check for Portainer when possible.
# If Cup says the configured Portainer image is current, the script can skip
# an unnecessary docker pull. Docker image ID comparison is still the final
# authority when an update is attempted.
PORTAINER_USE_CUP_PRECHECK="true"

# Publish Portainer Edge Agent tunnel port 8000.
PORTAINER_ENABLE_EDGE_PORT="true"

# Publish legacy HTTP UI port 9000.
# New installs usually do not need this.
PORTAINER_ENABLE_LEGACY_HTTP_PORT="false"

# Optional safety gate before recreating Portainer.
# If enabled for non-interactive runs, also set:
#   PORTAINER_BACKUP_ACKNOWLEDGED=1
#
# PORTAINER_REQUIRE_BACKUP_BEFORE_UPDATE="true"

# Examples:
#
# Use STS instead of LTS:
# PORTAINER_RELEASE_STREAM="sts"
#
# Pin a specific custom image:
# PORTAINER_RELEASE_STREAM="custom"
# PORTAINER_IMAGE="portainer/portainer-ce:2.40.0"


########################################
# CUP
########################################

# Enable Cup integration.
# Cup is used for image update visibility and selective stack matching.
CUP_ENABLED="true"

# Cup URL reachable from the host running stack-updater.sh.
CUP_URL="http://127.0.0.1:8000"

# Refresh Cup before reading /api/v3/json.
# Disable this if you prefer Cup's own refresh_interval.
CUP_REFRESH_BEFORE_CHECK="true"

# Curl timeout for Cup refresh/json calls.
CUP_REFRESH_TIMEOUT_SECONDS="60"


########################################
# STACK UPDATE ORDER
########################################

# These are Portainer stack names, not container names.
#
# Format:
#   DEPENDENCY_STACKS=(
#     "stack-name"
#   )
#
# Rules:
# - One double-quoted stack name per line.
# - No commas.
# - Use normal ASCII quotes.

# Stacks that must update first.
# Example: VPN, reverse proxy, shared database.
DEPENDENCY_STACKS=()

# Stacks that depend on dependency stacks.
# Example: apps that route through a VPN stack.
DEPENDENT_STACKS=()

# Stacks that should never be updated by this script.
EXCLUDED_STACKS=()

# Stacks that need extra wait time after redeploy.
# Example: Immich, Frigate, large databases, AI/web UI stacks.
HEAVY_STACKS=()


########################################
# WAIT TIMES
########################################

# Default wait after each stack redeploy.
DEFAULT_STACK_SLEEP_SECONDS=10

# Extra wait after dependency stacks.
DEPENDENCY_SETTLE_SECONDS=90

# Wait after dependent stacks.
DEPENDENT_STACK_SLEEP_SECONDS=30

# Wait after heavy stacks.
HEAVY_STACK_SLEEP_SECONDS=45


########################################
# DOCKER CLEANUP
########################################

# Remove unused Docker images.
PRUNE_UNUSED_IMAGES="true"

# Remove unused Docker networks.
PRUNE_UNUSED_NETWORKS="true"

# Remove unused Docker volumes.
#
# Disabled by default for safety. Unused volumes can still contain important
# application data if they are detached from containers.
PRUNE_UNUSED_VOLUMES="false"

# One-shot cleanup overrides:
#
# Disable network prune for one run:
#   PRUNE_NETWORKS=0 ./stack-updater.sh
#
# Enable volume prune for one run:
#   PRUNE_VOLUMES=1 ./stack-updater.sh --phase cleanup